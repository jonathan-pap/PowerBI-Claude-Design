-- Target Bar SVG — Horizontal Track with Coloured Zones and Needle
-- dataType: Text, dataCategory: ImageUrl
-- Target visual: Image or Card (viewBox 320 x 60)
-- Pattern: three coloured performance zones + a diamond needle showing the current value
-- Replace [Cache Hit Ratio %] with your 0..1 measure
-- Fixed: hex colors use # directly (NOT %23 URL encoding)

Cache Hit Ratio SVG =
VAR _ratio  = [Cache Hit Ratio %]                   -- 0..1
VAR _pct    = MIN ( MAX ( _ratio, 0 ), 1 ) * 100    -- clamp to 0..100
VAR _w      = 320
VAR _h      = 60
VAR _x0     = 10      -- track left edge
VAR _x1     = 300     -- track right edge
VAR _trackW = _x1 - _x0
VAR _needleX = _x0 + _trackW * _pct / 100

VAR _svg =
    "data:image/svg+xml;utf8," &
    "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 " & _w & " " & _h & "' font-family='Segoe UI, Arial, sans-serif'>" &

    -- Three coloured zone bands
    "<rect x='" & _x0 & "' y='28' width='" & ( _trackW * 0.30 ) & "' height='10' fill='#f4d4d0'/>" &
    "<rect x='" & ( _x0 + _trackW * 0.30 ) & "' y='28' width='" & ( _trackW * 0.40 ) & "' height='10' fill='#f5e1c8'/>" &
    "<rect x='" & ( _x0 + _trackW * 0.70 ) & "' y='28' width='" & ( _trackW * 0.30 ) & "' height='10' fill='#d6e7d3'/>" &

    -- Thin baseline across all zones
    "<line x1='" & _x0 & "' y1='32' x2='" & _x1 & "' y2='32' stroke='#222222' stroke-width='1'/>" &

    -- Tick labels
    "<g fill='#888888' font-size='11'>" &
        "<text x='" & _x0 & "' y='52'>0</text>" &
        "<text x='" & ( _x0 + _trackW * 0.30 - 6 ) & "' y='52'>30</text>" &
        "<text x='" & ( _x0 + _trackW * 0.70 - 6 ) & "' y='52'>70</text>" &
        "<text x='" & ( _x1 - 12 ) & "' y='52'>100</text>" &
    "</g>" &

    -- Needle stem
    "<line x1='" & _needleX & "' y1='18' x2='" & _needleX & "' y2='42' stroke='#c97a3a' stroke-width='1.5'/>" &

    -- Diamond needle head
    "<polygon points='" &
        _needleX & ",14 " &
        ( _needleX + 5 ) & ",19 " &
        _needleX & ",24 " &
        ( _needleX - 5 ) & ",19" &
    "' fill='#c97a3a'/>" &

    "</svg>"

RETURN _svg
