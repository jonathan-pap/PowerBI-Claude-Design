	/// Standard retail list price for one unit of this product.
	column 'Unit Price'
		dataType: decimal
		isHidden
		formatString: 0.00
		lineageTag: 84d52a8b-c0d0-4107-85bd-5b4d23ee0e63
		summarizeBy: none
		sourceColumn: Unit Price

		changedProperty = IsHidden

		changedProperty = FormatString

		annotation SummarizationSetBy = Automatic

	/// Numeric code identifying the product subcategory.
	column 'Subcategory Code'
		dataType: int64
		isHidden
		formatString: 0
		lineageTag: 00a5e37d-b1d2-4973-b7df-2d1660444ba2
		summarizeBy: none
		sourceColumn: Subcategory Code

		changedProperty = IsHidden

