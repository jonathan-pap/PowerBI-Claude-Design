	/// Numeric code identifying the top-level product category.
	column 'Category Code'
		dataType: int64
		isHidden
		formatString: 0
		lineageTag: d8356f1b-3670-4a5e-b4c2-5478ea395412
		summarizeBy: none
		sourceColumn: Category Code

