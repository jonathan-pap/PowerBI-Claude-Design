	/// Product subcategory name (child of Category).
	column Subcategory
		dataType: string
		lineageTag: e8364556-174b-48bd-86b7-8ee993ed42b2
		summarizeBy: none
		sourceColumn: Subcategory
		sortByColumn: 'Subcategory Code'

		changedProperty = SortByColumn

