		sourceColumn: Category
		sortByColumn: 'Category Code'

		changedProperty = SortByColumn

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isText":true}

	/// Two-level product classification hierarchy: Category (top-level) → Subcategory (child).
	hierarchy Category-Subcategory
		lineageTag: 5ec65955-39d4-40e1-bd2c-cf6893d6da39

		/// Top level. Broadest product grouping (e.g. Electronics, Clothing).
		level Category
			lineageTag: 01e62e60-0cc5-436c-87c9-05a7bcf9a2a4
			column: Category

		/// Lowest level. Product subcategory within the selected category.
		level Subcategory
			lineageTag: 1bd073a3-ffc9-4092-bdc0-b1c315a4ad75
			column: Subcategory

