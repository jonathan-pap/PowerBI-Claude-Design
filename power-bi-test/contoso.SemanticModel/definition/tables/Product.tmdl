	/// Standard cost to procure or produce one unit of this product.
	column 'Unit Cost'
		dataType: decimal
		isHidden
		formatString: 0.00
		lineageTag: 7e8dbbf9-2d41-45d3-8ced-043c19f86f7f
		summarizeBy: none
		sourceColumn: Unit Cost

		changedProperty = IsHidden

		changedProperty = FormatString

