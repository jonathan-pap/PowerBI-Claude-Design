/// Product dimension. One row per product. Full catalogue with category/subcategory hierarchy, pricing, and physical attributes.
table Product
	lineageTag: 788e06ac-419f-4210-be7d-232115f91c18

	/// Primary key uniquely identifying each product.
	column ProductKey
		dataType: int64
		isHidden
		formatString: 0
		lineageTag: de8b0944-7e1e-43ab-9f3d-900e55258e76
		summarizeBy: none
		sourceColumn: ProductKey

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	/// Internal SKU or product code.
	column 'Product Code'
		dataType: string
		lineageTag: 28a3ad1a-2f34-4aaa-ac38-c0fbcbb98f81
		summarizeBy: none
		sourceColumn: Product Code

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isText":true}

