	column 'Product Name'
		dataType: string
		lineageTag: a9984409-56bd-49c0-ab0e-0f1f5d1778df
		summarizeBy: none
		sourceColumn: Product Name

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isText":true}

	/// Company that manufactures the product.
	column Manufacturer
		dataType: string
		lineageTag: 06d0bedb-8e42-4069-b7d7-6273e4eaac2b
		summarizeBy: none
		sourceColumn: Manufacturer

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isText":true}

	/// Brand name under which the product is sold.
	column Brand
		dataType: string
		lineageTag: dde298a7-1cf1-49cb-8afd-51b2e855f8c6
		summarizeBy: none
		sourceColumn: Brand

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isText":true}

	/// Primary color of the product.
	column Color
		dataType: string
		lineageTag: d50599a0-bfc6-45ad-bbf9-7518a18d69c1
		summarizeBy: none
		sourceColumn: Color

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isText":true}

	/// Unit of measurement for the product's weight (e.g. kg, lb).
	column 'Weight Unit Measure'
		dataType: string
		isHidden
		lineageTag: 6445f84d-268d-4836-b857-a713609618c7
